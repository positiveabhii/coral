{
  "name": "coral-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cargo run --manifest-path ../Cargo.toml -p coral-cli --features server -- server",
    "dev:local": "concurrently --kill-others --names api,ui --prefix-colors blue,green \"npm:dev:server\" \"npm:dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.10"
  }
}
